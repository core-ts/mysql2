{
  "compileOnSave": true,
  "compilerOptions": {
    "target": "es6",
    "rootDir": "./src",
    "outDir": "./lib",
    "module": "node16",
    "moduleResolution": "node16",
    "strict": true,
    "pretty": true,
    "sourceMap": false,
    "declaration": false,
    "experimentalDecorators": false,
    "removeComments": true,
    "lib": [
      "es6"
    ]
  },
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
